{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minuta",
  "version": "0.1.0",
  "identifier": "com.minuta.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @minuta/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @minuta/desktop build",
    "frontendDist": "../apps/desktop/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Minuta",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
